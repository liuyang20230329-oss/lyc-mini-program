# ========== 服务配置 ==========
PORT=3002
API_BASE=/api/v1
NODE_ENV=development

# ========== 存储模式 ==========
# local = 本地磁盘 (开发)
# oss   = 阿里云 OSS (生产)
STORAGE_MODE=local

# ========== 阿里云短信 SMS ==========
SMS_DEV_MODE=true
ALIYUN_SMS_ACCESS_KEY_ID=your-sms-access-key-id
ALIYUN_SMS_ACCESS_KEY_SECRET=your-sms-access-key-secret
ALIYUN_SMS_SIGN_NAME=LYC小宇宙学堂
ALIYUN_SMS_TEMPLATE_CODE=SMS_123456789

# ========== 阿里云 OSS ==========
OSS_REGION=oss-cn-hangzhou
OSS_ACCESS_KEY_ID=your-access-key-id
OSS_ACCESS_KEY_SECRET=your-access-key-secret
OSS_BUCKET=lyc-media
OSS_ENDPOINT=https://oss-cn-hangzhou.aliyuncs.com

# ========== CDN ==========
CDN_DOMAIN=
# 例如 cdn.lyc.example.com，留空则使用 OSS 默认域名

# ========== JWT ==========
JWT_SECRET=lyc-dev-secret-change-in-production
JWT_EXPIRES_IN=7d

# ========== 上传限制 ==========
UPLOAD_MAX_FILE_SIZE=209715200
UPLOAD_CHUNK_SIZE=5242880

# ========== 本地存储路径 (开发模式) ==========
LOCAL_UPLOAD_DIR=./data/uploads

# ========== 数据库 ==========
DB_PATH=./data/lyc-media.db

# ========== 管理后台 ==========
ADMIN_API_KEY=lyc-admin-dev

# ========== 阿里云 TTS 语音合成 ==========
TTS_DEV_MODE=true
ALIYUN_TTS_APP_KEY=your-tts-app-key
ALIYUN_TTS_ACCESS_KEY=your-tts-access-key
ALIYUN_TTS_ACCESS_SECRET=your-tts-access-secret

# ========== 阿里云 ASR 语音识别 ==========
ALIYUN_ASR_APP_KEY=your-asr-app-key
ALIYUN_ASR_ACCESS_KEY=your-asr-access-key
ALIYUN_ASR_ACCESS_SECRET=your-asr-access-secret
ALIYUN_ASR_URL=https://fileasr.cn-beijing.aliyuncs.com
