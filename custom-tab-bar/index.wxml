<view class="tabbar-shell">
  <view class="tabbar-panel">
    <view
      wx:for="{{list}}"
      wx:key="pagePath"
      class="tabbar-item"
      data-index="{{index}}"
      data-path="{{item.pagePath}}"
      bindtap="switchTab"
    >
      <image
        class="tabbar-icon"
        src="{{selected === index ? item.selectedIconPath : item.iconPath}}"
        mode="aspectFit"
      />
      <text class="tabbar-label {{selected === index ? 'tabbar-label-active' : ''}}">
        {{item.text}}
      </text>
    </view>
  </view>
</view>
