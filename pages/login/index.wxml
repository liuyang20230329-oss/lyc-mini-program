<!-- Template overview: pages\login\index.wxml -->
<view class="login-page">
  <view class="login-hero">
    <view class="login-logo">LYC</view>
    <view class="login-app-name">小宇宙学堂</view>
    <view class="login-slogan">每天十分钟，和孩子一起听、读、唱</view>
  </view>

  <view class="login-form" wx:if="{{mode === 'phone'}}">
    <view class="form-group">
      <input
        class="form-input"
        type="number"
        maxlength="11"
        placeholder="请输入手机号"
        value="{{phoneNumber}}"
        bindinput="onPhoneInput"
      />
    </view>
    <view class="form-group form-row">
      <input
        class="form-input form-input-code"
        type="number"
        maxlength="6"
        placeholder="验证码"
        value="{{smsCode}}"
        bindinput="onCodeInput"
      />
      <view
        class="form-code-btn {{countdown > 0 ? 'form-code-disabled' : ''}}"
        bindtap="sendCode"
      >
        {{countdown > 0 ? countdown + 's' : '获取验证码'}}
      </view>
    </view>
    <view class="form-btn form-btn-primary" bindtap="smsLogin">
      {{isRegister ? '注册并登录' : '登录'}}
    </view>
    <view class="form-switch" bindtap="switchToWx">
      使用微信登录
    </view>
  </view>

  <view class="login-form" wx:if="{{mode === 'wx'}}">
    <view class="form-btn form-btn-wx" bindtap="wxLogin">
      <text class="wx-icon">💬</text> 微信一键登录
    </view>
    <view class="form-btn form-btn-phone-entry" bindtap="switchToPhone">
      手机号登录
    </view>
  </view>

  <view class="login-form" wx:if="{{mode === 'setup'}}">
    <view class="setup-title">完善宝贝信息</view>
    <view class="setup-subtitle">帮助我们推荐更适合的内容</view>
    <view class="form-group">
      <input class="form-input" placeholder="宝贝昵称" value="{{childNickname}}" bindinput="onChildNicknameInput" />
    </view>
    <view class="form-group">
      <picker mode="multiSelector" range="{{ageRanges}}" value="{{ageIndex}}" bindchange="onAgePick">
        <view class="form-input form-input-picker">
          {{ageDisplay || '选择年龄'}}
        </view>
      </picker>
    </view>
    <view class="form-group gender-row">
      <view class="gender-btn {{childGender === 'male' ? 'gender-active' : ''}}" bindtap="pickGender" data-gender="male">男孩</view>
      <view class="gender-btn {{childGender === 'female' ? 'gender-active' : ''}}" bindtap="pickGender" data-gender="female">女孩</view>
      <view class="gender-btn {{childGender === 'undisclosed' ? 'gender-active' : ''}}" bindtap="pickGender" data-gender="undisclosed">保密</view>
    </view>
    <view class="form-btn form-btn-primary" bindtap="submitSetup">开始学习</view>
    <view class="form-switch" bindtap="skipSetup">稍后再填</view>
  </view>

  <view class="login-footer">
    登录即表示同意
    <text class="login-link">《用户协议》</text>
    和
    <text class="login-link">《隐私政策》</text>
  </view>
</view>
