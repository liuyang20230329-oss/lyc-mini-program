/* Style overview: pages\login\index.wxss */
.login-page { min-height: 100vh; background: linear-gradient(180deg, #fff8ee 0%, #fff 50%); padding: 0 48rpx; display: flex; flex-direction: column; }
.login-hero { text-align: center; padding: 120rpx 0 60rpx; }
.login-logo { font-size: 72rpx; font-weight: 900; color: #ff8f62; letter-spacing: 4rpx; }
.login-app-name { font-size: 36rpx; font-weight: 800; color: #2f3a4a; margin-top: 12rpx; }
.login-slogan { font-size: 26rpx; color: #7b8798; margin-top: 16rpx; }
.login-form { margin-top: 40rpx; }
.form-group { margin-bottom: 24rpx; }
.form-row { display: flex; gap: 16rpx; }
.form-input { width: 100%; height: 88rpx; padding: 0 28rpx; border-radius: 24rpx; border: 2rpx solid #edf0f5; font-size: 30rpx; color: #2f3a4a; background: #fff; box-sizing: border-box; }
.form-input-code { flex: 1; width: auto; }
.form-input-picker { display: flex; align-items: center; color: #2f3a4a; line-height: 88rpx; }
.form-code-btn { width: 200rpx; height: 88rpx; line-height: 88rpx; text-align: center; border-radius: 24rpx; font-size: 26rpx; font-weight: 700; color: #ff8f62; background: #fff5ef; flex-shrink: 0; }
.form-code-disabled { color: #b0b8c4; background: #f6f8fc; }
.form-btn { width: 100%; height: 96rpx; line-height: 96rpx; text-align: center; border-radius: 28rpx; font-size: 32rpx; font-weight: 800; margin-bottom: 24rpx; }
.form-btn-primary { background: linear-gradient(135deg, #ff8f62 0%, #ff6b3d 100%); color: #fff; }
.form-btn-wx { background: #07c160; color: #fff; display: flex; align-items: center; justify-content: center; gap: 12rpx; }
.wx-icon { font-size: 36rpx; }
.form-btn-phone-entry { background: #f6f8fc; color: #4f5f73; }
.form-switch { text-align: center; font-size: 26rpx; color: #7b8798; padding: 16rpx; }
.setup-title { font-size: 36rpx; font-weight: 800; color: #2f3a4a; margin-bottom: 8rpx; }
.setup-subtitle { font-size: 26rpx; color: #7b8798; margin-bottom: 36rpx; }
.gender-row { display: flex; gap: 16rpx; }
.gender-btn { flex: 1; height: 80rpx; line-height: 80rpx; text-align: center; border-radius: 20rpx; font-size: 28rpx; color: #4f5f73; background: #f6f8fc; border: 2rpx solid transparent; }
.gender-active { color: #ff8f62; border-color: rgba(255, 143, 98, 0.4); background: #fff9f3; }
.login-footer { margin-top: auto; padding: 40rpx 0; text-align: center; font-size: 22rpx; color: #b0b8c4; }
.login-link { color: #7b8798; }
