.growth-hero {
  background: linear-gradient(160deg, #ffd7a6 0%, #fff7d9 100%);
}

.growth-title {
  margin-top: 18rpx;
  font-size: 44rpx;
  font-family: var(--font-display);
  font-weight: 900;
  letter-spacing: 1.5rpx;
  line-height: 1.35;
  text-shadow: var(--title-shadow-soft);
  color: #2f3a4a;
}

.growth-text {
  margin-top: 16rpx;
  font-size: 26rpx;
  line-height: 1.7;
  color: #455469;
}

.guest-cta {
  margin-top: 26rpx;
}

.guest-panel {
  margin-top: 24rpx;
}

.guest-panel-title {
  font-size: 30rpx;
  font-weight: 800;
  color: #2f3a4a;
  margin-bottom: 20rpx;
}

.week-chart {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  height: 220rpx;
}

.week-item {
  width: 13%;
  text-align: center;
}

.week-bar-wrap {
  height: 180rpx;
  display: flex;
  align-items: flex-end;
  justify-content: center;
}

.week-bar {
  width: 44rpx;
  border-radius: 999rpx;
  background: linear-gradient(180deg, #9cd6ff 0%, #ffb870 100%);
}

.week-day {
  margin-top: 16rpx;
  font-size: 22rpx;
  color: #6f7f92;
}

.goal-item {
  display: flex;
  align-items: center;
}

.goal-item + .goal-item {
  margin-top: 18rpx;
}

.goal-dot {
  width: 16rpx;
  height: 16rpx;
  margin-right: 18rpx;
  border-radius: 50%;
  background: #ff9d70;
}

.goal-text {
  flex: 1;
  font-size: 26rpx;
  line-height: 1.6;
  color: #445367;
}

.mission-card {
  margin-top: 18rpx;
}

.mission-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
}

.mission-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #2f3a4a;
}

.mission-detail {
  margin-top: 14rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: #55667a;
}

.mission-done {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 168rpx;
  height: 84rpx;
  margin-top: 22rpx;
  padding: 0 28rpx;
  border-radius: 999rpx;
  font-size: 28rpx;
  font-weight: 700;
  color: #5d6b7d;
  background: #eef2f7;
}

.badge-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
}

.badge-card {
  width: 48%;
  min-height: 220rpx;
  margin-bottom: 18rpx;
}

.badge-card-active {
  background: linear-gradient(180deg, #fff6ea 0%, #ffffff 100%);
}

.badge-card-muted {
  opacity: 0.72;
}

.badge-name {
  font-size: 30rpx;
  font-weight: 700;
  color: #2f3a4a;
}

.badge-desc {
  margin: 16rpx 0 20rpx;
  font-size: 24rpx;
  line-height: 1.65;
  color: #5a6a7e;
}

.growth-return {
  margin-top: 10rpx;
  background: linear-gradient(160deg, #d9f1ff 0%, #fff4de 100%);
}

.growth-return-title {
  font-size: 34rpx;
  font-family: var(--font-display);
  font-weight: 800;
  color: #2f3a4a;
}

.growth-return-text {
  margin: 14rpx 0 22rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: #55667a;
}
