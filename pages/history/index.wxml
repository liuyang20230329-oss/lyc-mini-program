<view class="page-shell page-shell-tabbed">
  <block wx:if="{{isGuestMode}}">
    <view class="hero-card growth-hero fade-up">
      <text class="tag">成长记录</text>
      <view class="growth-title">登录后把每一次学习都变成看得见的成长</view>
      <view class="growth-text">
        现在可以先试听内容，登录后就能自动保存成长星星、学习时长和连续学习天数。
      </view>
      <view class="metric-row">
        <view class="metric-box">
          <text class="metric-value">30秒</text>
          <text class="metric-label">单次试听</text>
        </view>
        <view class="metric-box">
          <text class="metric-value">3次</text>
          <text class="metric-label">每日体验</text>
        </view>
        <view class="metric-box">
          <text class="metric-value">同步</text>
          <text class="metric-label">登录后解锁</text>
        </view>
      </view>
      <view class="action-primary guest-cta" bindtap="openContinue">登录查看成长记录</view>
    </view>

    <view class="surface-card guest-panel fade-up">
      <view class="guest-panel-title">登录后你会看到</view>
      <view class="goal-item">
        <text class="goal-dot"></text>
        <text class="goal-text">孩子累计获得了多少成长星星</text>
      </view>
      <view class="goal-item">
        <text class="goal-dot"></text>
        <text class="goal-text">最近一周哪几天学习状态更稳定</text>
      </view>
      <view class="goal-item">
        <text class="goal-dot"></text>
        <text class="goal-text">哪些任务已经完成，下一步适合学什么</text>
      </view>
    </view>
  </block>

  <block wx:else>
    <view class="hero-card growth-hero fade-up">
      <text class="tag">成长记录</text>
      <view class="growth-title">把每一次开口和倾听都变成看得见的进步</view>
      <view class="growth-text">这一版先展示演示数据，后面接入云开发后就能保存真实学习轨迹。</view>
      <view class="metric-row">
        <view class="metric-box">
          <text class="metric-value">{{totalStars}}</text>
          <text class="metric-label">星星总数</text>
        </view>
        <view class="metric-box">
          <text class="metric-value">{{streakDays}}</text>
          <text class="metric-label">连续天数</text>
        </view>
        <view class="metric-box">
          <text class="metric-value">{{totalMinutes}}</text>
          <text class="metric-label">学习分钟</text>
        </view>
      </view>
    </view>

    <view class="section-head">
      <view>
        <view class="section-title">一周节奏</view>
        <view class="section-caption">简单的可视化，会让家长更容易看见孩子的稳定性。</view>
      </view>
    </view>

    <view class="surface-card fade-up">
      <view class="week-chart">
        <view class="week-item" wx:for="{{weekProgress}}" wx:key="day">
          <view class="week-bar-wrap">
            <view class="week-bar" style="height: {{item.value * 24}}rpx;"></view>
          </view>
          <view class="week-day">{{item.day}}</view>
        </view>
      </view>
    </view>

    <view class="section-head">
      <view>
        <view class="section-title">今日任务</view>
        <view class="section-caption">首版保留轻激励，不让页面变成打卡压力。</view>
      </view>
    </view>

    <view
      wx:for="{{missions}}"
      wx:key="id"
      class="surface-card mission-card fade-up"
    >
      <view class="mission-top">
        <view class="mission-title">{{item.title}}</view>
        <view class="soft-chip">{{item.reward}}</view>
      </view>
      <view class="mission-detail">{{item.detail}}</view>
      <view
        class="{{item.done ? 'mission-done' : 'action-primary'}}"
        data-title="{{item.title}}"
        bindtap="claimMission"
      >
        {{item.done ? '已完成' : '记录一下'}}
      </view>
    </view>

    <view class="section-head">
      <view>
        <view class="section-title">已获得徽章</view>
        <view class="section-caption">小朋友会很喜欢这种“被看见”的反馈。</view>
      </view>
    </view>

    <view class="badge-grid">
      <view
        wx:for="{{badges}}"
        wx:key="id"
        class="surface-card badge-card fade-up {{item.unlocked ? 'badge-card-active' : 'badge-card-muted'}}"
      >
        <view class="badge-name">{{item.name}}</view>
        <view class="badge-desc">{{item.description}}</view>
        <view class="soft-chip">{{item.unlocked ? '已解锁' : '努力中'}}</view>
      </view>
    </view>

    <view class="hero-card growth-return fade-up">
      <view class="growth-return-title">继续今天的学习旅程</view>
      <view class="growth-return-text">{{continueLesson.title}} 还在等孩子继续听下去。</view>
      <view class="action-primary" bindtap="openContinue">去继续学习</view>
    </view>
  </block>

  <login-sheet
    visible="{{showLoginSheet}}"
    title="{{loginSheet.title}}"
    body="{{loginSheet.body}}"
    primaryText="{{loginSheet.primaryText}}"
    secondaryText="{{loginSheet.secondaryText}}"
    bind:confirm="handleLoginConfirm"
    bind:cancel="closeLoginSheet"
    bind:close="closeLoginSheet"
  />
</view>
