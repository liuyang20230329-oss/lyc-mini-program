.discover-hero {
  background: linear-gradient(160deg, #d7f4e4 0%, #fff4d7 100%);
}

.discover-title {
  margin-top: 18rpx;
  font-size: 46rpx;
  font-family: var(--font-display);
  font-weight: 900;
  letter-spacing: 1.6rpx;
  text-shadow: var(--title-shadow-soft);
  color: #253245;
}

.discover-text {
  margin-top: 18rpx;
  font-size: 26rpx;
  line-height: 1.7;
  color: #415165;
}

.discover-stats {
  margin-top: 18rpx;
  font-size: 24rpx;
  color: #5d6b7d;
}

.category-scroll {
  margin-top: 26rpx;
  white-space: nowrap;
}

.category-row {
  display: inline-flex;
}

.category-pill {
  width: 250rpx;
  margin-right: 18rpx;
  padding: 24rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.92);
  box-shadow: 0 14rpx 24rpx rgba(47, 58, 74, 0.08);
}

.category-pill-active {
  background: linear-gradient(160deg, #ffe4bc 0%, #fff9f0 100%);
  border: 2rpx solid rgba(255, 143, 98, 0.35);
}

.category-name {
  font-size: 30rpx;
  font-weight: 700;
  color: #2f3a4a;
}

.category-desc {
  margin-top: 12rpx;
  font-size: 22rpx;
  line-height: 1.6;
  color: #69788d;
}
