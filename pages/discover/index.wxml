<view class="page-shell page-shell-tabbed">
  <view class="hero-card discover-hero fade-up">
    <text class="tag">{{currentCategory.badge}}</text>
    <view class="discover-title">{{currentCategory.heroTitle}}</view>
    <view class="discover-text">{{currentCategory.heroText}}</view>
    <view class="discover-stats">{{currentCategory.stats}}</view>
  </view>

  <scroll-view class="category-scroll" scroll-x="true" show-scrollbar="false">
    <view class="category-row">
      <view
        wx:for="{{categories}}"
        wx:key="id"
        class="category-pill {{currentCategoryId === item.id ? 'category-pill-active' : ''}}"
        data-id="{{item.id}}"
        bindtap="handleCategoryTap"
      >
        <view class="category-name">{{item.name}}</view>
        <view class="category-desc">{{item.subtitle}}</view>
      </view>
    </view>
  </scroll-view>

  <view class="section-head">
    <view>
      <view class="section-title">{{currentCategory.name}}</view>
      <view class="section-caption">首版先放演示内容，后续可以继续按主题扩充。</view>
    </view>
  </view>

  <view class="list-block">
    <lesson-card
      wx:for="{{lessonList}}"
      wx:key="id"
      item="{{item}}"
      bind:select="handleLessonSelect"
    />
  </view>
</view>
