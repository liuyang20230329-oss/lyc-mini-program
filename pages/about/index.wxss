.parent-hero {
  background: linear-gradient(160deg, #d9f1ff 0%, #fef3dc 100%);
}

.parent-title {
  margin-top: 18rpx;
  font-size: 42rpx;
  font-family: var(--font-display);
  font-weight: 900;
  letter-spacing: 1.4rpx;
  line-height: 1.35;
  text-shadow: var(--title-shadow-soft);
  color: #2f3a4a;
}

.parent-text {
  margin-top: 16rpx;
  font-size: 26rpx;
  line-height: 1.7;
  color: #455469;
}

.guest-cta {
  margin-top: 26rpx;
}

.guest-panel {
  margin-top: 24rpx;
}

.guest-panel-title {
  font-size: 30rpx;
  font-weight: 800;
  color: #2f3a4a;
  margin-bottom: 20rpx;
}

.account-card {
  margin-top: 24rpx;
}

.account-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.account-name {
  font-size: 32rpx;
  font-weight: 800;
  color: #2f3a4a;
}

.account-note {
  margin-top: 12rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: #57677a;
}

.parent-summary-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
}

.parent-summary-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #2f3a4a;
}

.parent-summary-note {
  margin-top: 14rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: #57677a;
}

.schedule-card {
  background: linear-gradient(180deg, #fff9f0 0%, #ffffff 100%);
}

.schedule-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.schedule-name {
  font-size: 30rpx;
  font-weight: 700;
  color: #2f3a4a;
}

.schedule-item {
  display: flex;
  align-items: center;
  margin-top: 18rpx;
}

.schedule-item-text {
  flex: 1;
  font-size: 24rpx;
  line-height: 1.6;
  color: #57677a;
}

.goal-dot {
  width: 16rpx;
  height: 16rpx;
  margin-right: 18rpx;
  border-radius: 50%;
  background: #ff9d70;
}

.todo-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.todo-row + .todo-row {
  margin-top: 20rpx;
}

.todo-label {
  font-size: 28rpx;
  font-weight: 700;
  color: #2f3a4a;
}

.tip-item {
  display: flex;
  align-items: flex-start;
  margin-top: 22rpx;
}

.tip-text {
  flex: 1;
  font-size: 24rpx;
  line-height: 1.7;
  color: #5b6b7f;
}

.todo-text {
  font-size: 26rpx;
  line-height: 1.7;
  color: #4e5e72;
}

.parent-action {
  margin-top: 24rpx;
  background: linear-gradient(160deg, #dff5e6 0%, #ffffff 100%);
}

.parent-action-title {
  font-size: 34rpx;
  font-family: var(--font-display);
  font-weight: 800;
  color: #2f3a4a;
}

.parent-action-text {
  margin: 14rpx 0 22rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: #57677a;
}
