.custom-nav-shell {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 210;
  padding-left: 28rpx;
  padding-right: 28rpx;
  padding-bottom: 18rpx;
  background: linear-gradient(180deg, rgba(255, 248, 238, 0.98) 0%, rgba(255, 248, 238, 0.9) 62%, rgba(255, 248, 238, 0) 100%);
}

.custom-nav-panel {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.72);
  box-shadow: 0 12rpx 30rpx rgba(47, 58, 74, 0.08);
}

.custom-nav-spacer {
  width: 100%;
}

.custom-nav-inner {
  display: flex;
  align-items: center;
  width: 100%;
}

.custom-nav-side {
  flex-shrink: 0;
}

.custom-nav-title {
  flex: 1;
  text-align: center;
  font-family: var(--font-display);
  font-size: 34rpx;
  font-weight: 900;
  letter-spacing: 1.4rpx;
  color: #2f3a4a;
}

.hero-home {
  background: linear-gradient(160deg, #99d8ff 0%, #ffd4a0 100%);
}

.hero-glow {
  position: absolute;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.28);
}

.hero-glow-left {
  width: 210rpx;
  height: 210rpx;
  top: -42rpx;
  right: 38rpx;
}

.hero-glow-right {
  width: 132rpx;
  height: 132rpx;
  right: -18rpx;
  bottom: 42rpx;
}

.hero-title {
  position: relative;
  margin-top: 20rpx;
  font-size: 50rpx;
  font-family: var(--font-display);
  font-weight: 900;
  letter-spacing: 1.8rpx;
  line-height: 1.24;
  text-shadow: var(--title-shadow-soft);
  color: #223042;
}

.hero-subtitle {
  position: relative;
  margin-top: 18rpx;
  font-size: 27rpx;
  line-height: 1.7;
  color: #31455c;
}

.continue-card {
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.98) 0%, #fff4e8 100%);
}

.continue-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
}

.continue-label {
  font-size: 24rpx;
  color: #728397;
}

.continue-title {
  margin-top: 10rpx;
  font-size: 36rpx;
  font-family: var(--font-display);
  font-weight: 800;
  color: #2f3a4a;
}

.continue-summary {
  margin-top: 18rpx;
  font-size: 26rpx;
  line-height: 1.7;
  color: #4f5f73;
}

.continue-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 26rpx;
}

.continue-meta .soft-chip {
  margin-right: 12rpx;
}

.section-link {
  font-size: 24rpx;
  color: #ff8f62;
}

.portal-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
}

.bedtime-card {
  overflow: visible;
  background: linear-gradient(180deg, #dfe7ff 0%, #f8f8ff 100%);
}

.bedtime-copy {
  margin-bottom: 18rpx;
}

.bedtime-title {
  font-size: 34rpx;
  font-family: var(--font-display);
  font-weight: 800;
  color: #2f3a4a;
}

.bedtime-text {
  margin-top: 14rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: #56667b;
}

.bedtime-list {
  margin-top: 18rpx;
}
