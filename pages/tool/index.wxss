.detail-hero {
  background: linear-gradient(160deg, #ffdcb7 0%, #fff7ef 100%);
}

.detail-title {
  margin-top: 18rpx;
  font-size: 46rpx;
  font-family: var(--font-display);
  font-weight: 900;
  letter-spacing: 1.5rpx;
  text-shadow: var(--title-shadow-soft);
  color: #2f3a4a;
}

.detail-subtitle {
  margin-top: 10rpx;
  font-size: 26rpx;
  color: #69788d;
}

.detail-summary {
  margin-top: 18rpx;
  font-size: 26rpx;
  line-height: 1.7;
  color: #425267;
}

.detail-meta {
  margin-top: 20rpx;
}

.detail-meta .soft-chip {
  margin-right: 12rpx;
}

.trial-banner {
  margin-top: 24rpx;
  padding: 24rpx 28rpx;
  border-radius: 32rpx;
  background: linear-gradient(135deg, #fff4dd 0%, #fff9ef 100%);
  box-shadow: 0 18rpx 36rpx rgba(255, 166, 102, 0.12);
}

.trial-banner-text {
  font-size: 28rpx;
  font-weight: 700;
  color: #c66c33;
}

.trial-banner-meta {
  margin-top: 10rpx;
  font-size: 22rpx;
  line-height: 1.6;
  color: #8c6b57;
}

.action-panel {
  margin-top: 24rpx;
}

.action-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.action-row-bottom {
  margin-top: 22rpx;
}

.action-note {
  margin-top: 20rpx;
  padding: 18rpx 20rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: #6c7285;
  background: #f7f8fc;
}

.source-row + .source-row {
  margin-top: 18rpx;
}

.source-label {
  display: block;
  font-size: 22rpx;
  color: #7a8798;
}

.source-value {
  display: block;
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.65;
  color: #3f4f63;
  word-break: break-all;
}

.source-error {
  color: #d76656;
  font-weight: 700;
}

.goal-item {
  display: flex;
  align-items: center;
}

.goal-item + .goal-item {
  margin-top: 18rpx;
}

.goal-dot {
  width: 16rpx;
  height: 16rpx;
  margin-right: 18rpx;
  border-radius: 50%;
  background: #ff9d70;
}

.goal-text {
  flex: 1;
  font-size: 26rpx;
  line-height: 1.6;
  color: #445367;
}

.segment-card {
  margin-top: 18rpx;
  border: 2rpx solid transparent;
}

.segment-card-active {
  border-color: rgba(255, 143, 98, 0.4);
  background: linear-gradient(180deg, #fff9f3 0%, #ffffff 100%);
}

.segment-cue {
  font-size: 24rpx;
  color: #ff8f62;
}

.segment-text {
  margin-top: 12rpx;
  font-size: 34rpx;
  font-weight: 700;
  line-height: 1.45;
  color: #2f3a4a;
}

.segment-translation {
  margin-top: 14rpx;
  font-size: 26rpx;
  line-height: 1.7;
  color: #4f5f73;
}

.segment-tip {
  margin-top: 16rpx;
  padding: 18rpx 20rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: #627286;
  background: #f6f8fc;
}

.reward-card {
  margin-top: 26rpx;
  background: linear-gradient(160deg, #ffe4bc 0%, #fffaf3 100%);
}

.reward-title {
  font-size: 34rpx;
  font-family: var(--font-display);
  font-weight: 800;
  color: #2f3a4a;
}

.reward-text {
  margin-top: 14rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: #56667b;
}
