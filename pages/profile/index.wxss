/* Style overview: pages\profile\index.wxss */
.profile-page { padding: 32rpx; padding-bottom: 200rpx; background: #fff8ee; min-height: 100vh; }
.profile-header { display: flex; align-items: center; padding: 40rpx 32rpx; border-radius: 32rpx; background: linear-gradient(135deg, #ffdcb7 0%, #fff7ef 100%); box-shadow: 0 18rpx 40rpx rgba(47,58,74,0.06); }
.profile-avatar { width: 120rpx; height: 120rpx; border-radius: 50%; background: #ff8f62; display: flex; align-items: center; justify-content: center; margin-right: 28rpx; flex-shrink: 0; }
.avatar-text { font-size: 48rpx; font-weight: 800; color: #fff; }
.profile-info { flex: 1; }
.profile-nickname { font-size: 36rpx; font-weight: 800; color: #2f3a4a; }
.profile-phone { font-size: 24rpx; color: #7b8798; margin-top: 8rpx; }
.verified-badge { display: inline-block; padding: 2rpx 12rpx; border-radius: 12rpx; font-size: 20rpx; color: #07c160; background: #e8f5e9; margin-left: 8rpx; }
.unverified-text { color: #b0b8c4; }
.bind-btn { color: #ff8f62; font-weight: 700; margin-left: 12rpx; }
.login-btn { color: #ff8f62; font-weight: 700; }
.info-row { display: flex; justify-content: space-between; align-items: center; padding: 16rpx 0; }
.info-row + .info-row { border-top: 1rpx solid #f0f2f5; }
.info-label { font-size: 26rpx; color: #7b8798; }
.info-value { font-size: 26rpx; color: #2f3a4a; font-weight: 600; }
.info-link { font-size: 26rpx; color: #ff8f62; font-weight: 700; }
.empty-hint { font-size: 26rpx; color: #7b8798; margin-bottom: 20rpx; }
.menu-item { display: flex; justify-content: space-between; align-items: center; padding: 24rpx 0; }
.menu-item + .menu-item { border-top: 1rpx solid #f0f2f5; }
.menu-text { font-size: 28rpx; color: #2f3a4a; }
.menu-arrow { font-size: 32rpx; color: #b0b8c4; }
.menu-item-danger .menu-text { color: #d76656; }
