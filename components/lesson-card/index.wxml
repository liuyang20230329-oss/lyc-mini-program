<view
  class="lesson-card lesson-{{mode}} fade-up"
  bindtap="handleTap"
>
  <view class="lesson-cover">
    <text class="lesson-cover-label">{{item.coverLabel}}</text>
  </view>
  <view class="lesson-main">
    <view class="lesson-title">{{item.title}}</view>
    <view class="lesson-subtitle">{{item.subtitle}}</view>
    <view class="lesson-summary">{{item.summary}}</view>
    <view class="lesson-meta">
      <text class="lesson-chip">{{item.duration}}</text>
      <text class="lesson-chip">{{item.ageRange}}</text>
      <text class="lesson-chip">{{item.difficulty}}</text>
    </view>
  </view>
</view>
