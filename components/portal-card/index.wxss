.portal-card {
  min-height: 228rpx;
  padding: 28rpx;
  border-radius: 30rpx;
  box-shadow: 0 16rpx 32rpx rgba(47, 58, 74, 0.08);
}

.portal-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.portal-badge {
  display: inline-flex;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  color: #2f3a4a;
  background: rgba(255, 255, 255, 0.78);
}

.portal-arrow {
  font-size: 22rpx;
  color: #5d6b7d;
}

.portal-name {
  margin-top: 20rpx;
  font-size: 34rpx;
  font-weight: 700;
  color: #2f3a4a;
}

.portal-body {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
}

.portal-copy {
  flex: 1;
  min-width: 0;
}

.portal-subtitle {
  margin-top: 14rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: #4f5f73;
}

.portal-stats {
  margin-top: 18rpx;
  font-size: 22rpx;
  color: #5f7086;
}

.portal-icon {
  width: 112rpx;
  height: 112rpx;
  margin-left: 14rpx;
  flex-shrink: 0;
}

.tone-sky {
  background: linear-gradient(160deg, #d9f1ff 0%, #f2fbff 100%);
}

.tone-sun {
  background: linear-gradient(160deg, #ffe1b7 0%, #fff5e6 100%);
}

.tone-moon {
  background: linear-gradient(160deg, #dfe2ff 0%, #f5f6ff 100%);
}

.tone-mint {
  background: linear-gradient(160deg, #d9f5df 0%, #f2fff6 100%);
}
