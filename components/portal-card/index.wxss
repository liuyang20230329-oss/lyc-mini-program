/* Style overview: components\portal-card\index.wxss */
.portal-card {
  padding: 28rpx 28rpx;
  border-radius: 28rpx;
  background: #ffffff;
  box-shadow: 0 8rpx 24rpx rgba(47, 58, 74, 0.04);
}

.portal-card:active {
  opacity: 0.85;
}

.pc-badge {
  display: inline-block;
  padding: 6rpx 18rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  font-weight: 700;
  background: rgba(255, 143, 98, 0.12);
  color: #ff8f62;
  margin-bottom: 16rpx;
}

.pc-name {
  font-size: 32rpx;
  font-weight: 800;
  color: #2f3a4a;
}

.pc-subtitle {
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: #5a6a7e;
}

.pc-stats {
  margin-top: 14rpx;
  font-size: 22rpx;
  color: #8c96a8;
}
