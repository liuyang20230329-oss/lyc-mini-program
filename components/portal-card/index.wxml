<view
  class="portal-card tone-{{item.tone}} fade-up"
  bindtap="handleTap"
>
  <view class="portal-top">
    <text class="portal-badge">{{item.badge}}</text>
    <text class="portal-arrow">去看看</text>
  </view>
  <view class="portal-body">
    <view class="portal-copy">
      <view class="portal-name">{{item.name}}</view>
      <view class="portal-subtitle">{{item.subtitle}}</view>
      <view class="portal-stats">{{item.stats}}</view>
    </view>
    <image
      class="portal-icon"
      src="{{item.icon}}"
      mode="aspectFit"
    />
  </view>
</view>
