/* Style overview: components\voice-picker\index.wxss */
.vp-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 9999;
  background: rgba(0, 0, 0, 0.45);
  display: flex;
  align-items: flex-end;
  justify-content: center;
}
.vp-sheet {
  width: 100%;
  max-height: 80vh;
  padding: 36rpx 32rpx;
  padding-bottom: calc(36rpx + env(safe-area-inset-bottom));
  border-radius: 36rpx 36rpx 0 0;
  background: #ffffff;
  display: flex;
  flex-direction: column;
}
.vp-handle {
  width: 64rpx;
  height: 8rpx;
  margin: 0 auto 24rpx;
  border-radius: 4rpx;
  background: #e0e4ea;
}
.vp-title {
  font-size: 34rpx;
  font-weight: 800;
  color: #2f3a4a;
  margin-bottom: 6rpx;
}
.vp-subtitle {
  font-size: 24rpx;
  color: #7b8798;
  margin-bottom: 24rpx;
}
.vp-list {
  max-height: 50vh;
  margin-bottom: 24rpx;
}
.vp-item {
  display: flex;
  align-items: center;
  padding: 20rpx 16rpx;
  border-radius: 16rpx;
  margin-bottom: 8rpx;
  border: 2rpx solid transparent;
  transition: all 0.2s;
}
.vp-item-active {
  border-color: rgba(255, 143, 98, 0.4);
  background: #fff8ee;
}
.vp-avatar {
  font-size: 48rpx;
  margin-right: 20rpx;
  width: 80rpx;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  background: #f6f8fc;
  border-radius: 20rpx;
}
.vp-info {
  flex: 1;
}
.vp-name {
  font-size: 30rpx;
  font-weight: 700;
  color: #2f3a4a;
}
.vp-desc {
  font-size: 24rpx;
  color: #7b8798;
  margin-top: 2rpx;
}
.vp-check {
  width: 48rpx;
  height: 48rpx;
  line-height: 48rpx;
  text-align: center;
  border-radius: 50%;
  background: #ff8f62;
  color: #fff;
  font-size: 28rpx;
  font-weight: 700;
}
.vp-actions {
  display: flex;
  gap: 16rpx;
}
.vp-btn {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  border-radius: 24rpx;
  font-size: 30rpx;
  font-weight: 700;
}
.vp-btn-preview {
  background: #f6f8fc;
  color: #4f5f73;
}
.vp-btn-confirm {
  background: linear-gradient(135deg, #ff8f62, #ff6b3d);
  color: #fff;
}
