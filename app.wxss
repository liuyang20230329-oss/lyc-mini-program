/* Style overview: app.wxss */
page-shell {
  --font-display: -apple-system, 'PingFang SC', 'Helvetica Neue', sans-serif;
  --title-shadow-soft: 0 2rpx 8rpx rgba(47, 58, 74, 0.06);
}

page {
  background-color: #fff8ee;
  color: #2f3a4a;
  font-family: -apple-system, 'PingFang SC', 'Helvetica Neue', sans-serif;
  font-size: 28rpx;
  line-height: 1.6;
}

.page-shell {
  padding: 32rpx;
  padding-bottom: 180rpx;
}

.page-shell-tabbed {
  padding-bottom: 180rpx;
}

.hero-card {
  padding: 36rpx 32rpx;
  border-radius: 32rpx;
  box-shadow: 0 18rpx 40rpx rgba(47, 58, 74, 0.06);
}

.surface-card {
  padding: 28rpx 32rpx;
  border-radius: 28rpx;
  background: #ffffff;
  box-shadow: 0 8rpx 24rpx rgba(47, 58, 74, 0.04);
}

.tag {
  display: inline-block;
  padding: 6rpx 18rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  font-weight: 700;
  background: rgba(255, 143, 98, 0.12);
  color: #ff8f62;
}

.soft-chip {
  display: inline-block;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  color: #627286;
  background: #f6f8fc;
}

.action-primary {
  display: inline-block;
  padding: 18rpx 36rpx;
  border-radius: 24rpx;
  font-size: 28rpx;
  font-weight: 700;
  background: linear-gradient(135deg, #ff8f62 0%, #ff6b3d 100%);
  color: #fff;
  text-align: center;
}

.action-secondary {
  display: inline-block;
  padding: 18rpx 36rpx;
  border-radius: 24rpx;
  font-size: 28rpx;
  font-weight: 700;
  background: #f6f8fc;
  color: #4f5f73;
  text-align: center;
}

.section-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  margin: 36rpx 0 20rpx;
}

.section-title {
  font-size: 34rpx;
  font-weight: 800;
  color: #2f3a4a;
}

.section-caption {
  margin-top: 6rpx;
  font-size: 24rpx;
  color: #8c96a8;
  line-height: 1.5;
}

.list-block {
  margin-top: 16rpx;
}

.metric-row {
  display: flex;
  gap: 20rpx;
  margin-top: 28rpx;
}

.metric-box {
  flex: 1;
  text-align: center;
  padding: 20rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.6);
}

.metric-value {
  display: block;
  font-size: 36rpx;
  font-weight: 800;
  color: #2f3a4a;
}

.metric-label {
  display: block;
  margin-top: 6rpx;
  font-size: 22rpx;
  color: #7b8798;
}

.fade-up {
  margin-top: 24rpx;
}

.guest-cta {
  display: block;
  margin-top: 28rpx;
  text-align: center;
}

.tabbar-shell {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: 999;
}

.tabbar-panel {
  display: flex;
  background: #ffffff;
  border-top: 1rpx solid #f0f2f5;
  padding: 8rpx 0;
  padding-bottom: calc(8rpx + env(safe-area-inset-bottom));
}

.tabbar-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 8rpx 0;
}

.tabbar-icon {
  width: 44rpx;
  height: 44rpx;
}

.tabbar-label {
  margin-top: 4rpx;
  font-size: 20rpx;
  color: #7b8798;
}

.tabbar-label-active {
  color: #ff8f62;
  font-weight: 700;
}
