page {
  --font-ui: "PingFang SC", "Hiragino Sans GB", "Microsoft YaHei", sans-serif;
  --font-display: "Hannotate SC", "HanziPen SC", "Marker Felt", "Microsoft YaHei UI", "PingFang SC", "Hiragino Sans GB", sans-serif;
  --title-shadow-soft:
    0 4rpx 0 rgba(255, 255, 255, 0.52),
    0 12rpx 20rpx rgba(47, 58, 74, 0.08);
  min-height: 100%;
  background:
    radial-gradient(circle at top, rgba(143, 211, 255, 0.22), transparent 42%),
    linear-gradient(180deg, #fff8ee 0%, #fffdf8 100%);
  color: #2f3a4a;
  font-family: var(--font-ui);
}

view,
text,
button,
navigator {
  box-sizing: border-box;
}

button {
  padding: 0;
  background: transparent;
  line-height: inherit;
}

button::after {
  border: 0;
}

.page-shell {
  padding: 28rpx 28rpx 40rpx;
}

.page-shell-tabbed {
  padding-bottom: 220rpx;
}

.hero-card {
  position: relative;
  overflow: hidden;
  padding: 34rpx;
  border-radius: 36rpx;
  box-shadow: 0 18rpx 36rpx rgba(47, 58, 74, 0.1);
}

.surface-card {
  padding: 28rpx;
  border-radius: 30rpx;
  background: rgba(255, 255, 255, 0.96);
  box-shadow: 0 14rpx 30rpx rgba(47, 58, 74, 0.08);
}

.section-head {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  margin: 34rpx 0 22rpx;
}

.section-title {
  font-size: 34rpx;
  font-family: var(--font-display);
  font-weight: 800;
  letter-spacing: 1rpx;
  color: #2f3a4a;
}

.section-caption {
  margin-top: 8rpx;
  font-size: 24rpx;
  font-weight: 500;
  color: #738397;
}

.tag {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 700;
  color: #415165;
  background: rgba(255, 255, 255, 0.72);
}

.soft-chip {
  display: inline-flex;
  padding: 9rpx 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  color: #5d6b7d;
  background: #f6f7fb;
}

.action-primary,
.action-secondary {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 168rpx;
  height: 84rpx;
  padding: 0 28rpx;
  border-radius: 999rpx;
  font-size: 28rpx;
  font-weight: 700;
}

.action-primary {
  color: #ffffff;
  background: linear-gradient(135deg, #ffaf66 0%, #ff8f62 100%);
  box-shadow: 0 16rpx 24rpx rgba(255, 143, 98, 0.28);
}

.action-secondary {
  color: #425267;
  background: #ffffff;
}

.list-block + .list-block {
  margin-top: 20rpx;
}

.list-item + .list-item {
  margin-top: 16rpx;
}

.metric-row {
  display: flex;
  justify-content: space-between;
  margin-top: 24rpx;
}

.metric-box {
  width: 31.5%;
  padding: 22rpx 16rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.85);
  text-align: center;
}

.metric-value {
  display: block;
  font-size: 36rpx;
  font-family: var(--font-display);
  font-weight: 800;
  color: #2f3a4a;
}

.metric-label {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #64758a;
}

.fade-up {
  animation: fadeUp 0.5s ease both;
}

.float-slow {
  animation: floatSlow 3.2s ease-in-out infinite;
}

@keyframes fadeUp {
  from {
    opacity: 0;
    transform: translate3d(0, 20rpx, 0);
  }

  to {
    opacity: 1;
    transform: translate3d(0, 0, 0);
  }
}

@keyframes floatSlow {
  0% {
    transform: translateY(0);
  }

  50% {
    transform: translateY(-8rpx);
  }

  100% {
    transform: translateY(0);
  }
}
